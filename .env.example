# XScopeHub monitor-agent runtime

# Shared ports
PORT=8080
XSCOPE_OBSERVE_GATEWAY_PORT=8080
XSCOPE_LLM_OPS_AGENT_PORT=8100
XSCOPE_MCP_SERVER_PORT=8000

# Observe Gateway server
OBSERVE_GATEWAY_LISTEN_ADDR=:8080
OBSERVE_GATEWAY_TENANT_HEADER=X-Tenant
OBSERVE_GATEWAY_USER_HEADER=X-User
OBSERVE_GATEWAY_AUTH_ENABLED=false
OBSERVE_GATEWAY_JWKS_URL=
OBSERVE_GATEWAY_JWT_AUDIENCE=xscopehub
OBSERVE_GATEWAY_JWT_ISSUER=
OBSERVE_GATEWAY_CACHE_ENABLED=true
OBSERVE_GATEWAY_CACHE_TTL=1m

# Observability / OpenObserve upstream
OBSERVABILITY_BASE_URL=https://observability.svc.plus
OBSERVABILITY_OTEL_INGEST_URL=https://observability.svc.plus/ingest/otlp
OBSERVABILITY_OPENOBSERVE_BASE_URL=https://otel.svc.plus
OBSERVABILITY_OPENOBSERVE_ORG=default
OBSERVABILITY_OPENOBSERVE_API_KEY=
OBSERVABILITY_FALLBACK_PROM_BASE_URL=
OBSERVABILITY_FALLBACK_PROM_TOKEN=

# Observe Gateway caller identity used by llm-ops-agent and mcp-server
XSCOPE_DEFAULT_TENANT=default
XSCOPE_DEFAULT_USER=xscope-monitor
XSCOPE_OBSERVE_GATEWAY_URL=http://127.0.0.1:8080
XSCOPE_OBSERVE_GATEWAY_TOKEN=

# LLM Ops Agent analysis runtime
XSCOPE_LLM_OPS_AGENT_URL=http://127.0.0.1:8100
XSCOPE_ANALYSIS_TIMEOUT=2m
XSCOPE_ANALYSIS_DEFAULT_WINDOW=1h
XSCOPE_ANALYSIS_DEFAULT_STEP=5m
XSCOPE_ANALYSIS_MAX_EVIDENCE=3

# Codex embedded runtime
XSCOPE_CODEX_ENABLED=true
XSCOPE_CODEX_COMMAND=codex
XSCOPE_CODEX_MODEL=gpt-5.4
XSCOPE_CODEX_SANDBOX=read-only
XSCOPE_CODEX_TIMEOUT=120s
XSCOPE_CODEX_HOME=/Users/shenlan/workspaces/cloud-neutral-toolkit/x-scope-hub.svc.plus/.runtime/codex-home
XSCOPE_CODEX_CONFIG_PATH=/Users/shenlan/workspaces/cloud-neutral-toolkit/x-scope-hub.svc.plus/.runtime/codex-home/config.toml
XSCOPE_CODEX_MCP_SERVER_ID=xscopehub

# MCP Server
XSCOPE_MCP_SERVER_URL=http://127.0.0.1:8000/mcp
XSCOPE_MCP_SERVER_AUTH_TOKEN=
XSCOPE_MCP_SERVER_MANIFEST=/Users/shenlan/workspaces/cloud-neutral-toolkit/x-scope-hub.svc.plus/mcp-server/manifest.json

# OpenClaw Gateway integration
OPENCLAW_GATEWAY_URL=ws://127.0.0.1:18789
OPENCLAW_GATEWAY_TOKEN=
OPENCLAW_GATEWAY_PASSWORD=
OPENCLAW_PROFILE=default
OPENCLAW_ACP_BACKEND=acpx
OPENCLAW_AGENT_ID=x-observability-agent
OPENCLAW_AGENT_NAME=XScopeHub Observability
OPENCLAW_AGENT_WORKSPACE=/Users/shenlan/workspaces/cloud-neutral-toolkit/x-scope-hub.svc.plus
OPENCLAW_AGENT_MODEL=gpt-5.4
OPENCLAW_REGISTER_ON_START=false
OPENCLAW_CODEX_AGENT=codex
OPENCLAW_BINDINGS_CHANNEL=discord
OPENCLAW_BINDINGS_ACCOUNT=default
OPENCLAW_BINDINGS_PEER_ID=

# Unified AI gateway env contract for Codex/acpx runtimes
AI_GATEWAY_URL=
AI_GATEWAY_API_KEY=

# Legacy / compatibility
DATABASE_URL=postgres://postgres:postgres@localhost:5432/ops?sslmode=disable
OTEL_EXPORTER_OTLP_ENDPOINT=http://127.0.0.1:4317
NATS_URL=nats://127.0.0.1:4222
KAFKA_BROKERS=127.0.0.1:9092
